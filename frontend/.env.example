# ─── Site ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (EXISTING project — shared with the management panel; do not create a new one) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-only; never in the client bundle

# ─── Stripe (test mode first) ───
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (optional — contact form falls back to Supabase if unset) ───
RESEND_API_KEY=
