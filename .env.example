# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# n8n
N8N_WEBHOOK_BASE=https://YOUR_N8N_INSTANCE/webhook

# Email (Resend) — set as Supabase function secrets, not in the browser
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=noreply@abcac.org
ADMIN_EMAIL=abcac@abcac.org

# Stripe (payments) — set as Supabase function secrets, never in the browser
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Supabase service role — function secret only (full DB access; keep private)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Portal
VERCEL_URL=https://portal.abcac.org
